component CounterCard {
  div(isBoundary, className="capability capability-counter") {
    h2("Compiled counter")
    div("Count: {count:0}")
    button("+", on:click=increase)
    button("-", on:click=decrease)
  }
}

component EchoCard {
  handler updateMessage {
    update { echo: event.target.value }
  }

  div(isBoundary, className="capability capability-input") {
    h2("Compiled echo")
    input(placeholder="type here", on:input=updateMessage)
    div("Echo: {echo:}")
  }
}
