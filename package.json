{
  "name": "@xdstriker/pulsedom",
  "version": "0.1.2",
  "description": "Tiny tree-shakable DOM render library with an optional .pl component compiler.",
  "module": "./src/index.ts",
  "types": "./types/index.d.ts",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "dom",
    "render",
    "vdom",
    "tiny",
    "compiler",
    "bun"
  ],
  "files": [
    "src",
    "types",
    "compiler",
    "public",
    "index.js",
    "build.ts",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.ts"
    },
    "./virtual-node": {
      "types": "./types/virtual-node.d.ts",
      "import": "./src/core/virtualNode.ts"
    },
    "./store": {
      "types": "./types/store.d.ts",
      "import": "./src/store/tinyStore.ts"
    },
    "./template": {
      "types": "./types/template.d.ts",
      "import": "./src/core/template.ts"
    },
    "./compiler": {
      "types": "./types/compiler.d.ts",
      "import": "./compiler/compilePL.ts"
    },
    "./pl-plugin": {
      "types": "./types/pl-plugin.d.ts",
      "import": "./compiler/plPlugin.ts"
    }
  },
  "scripts": {
    "compile:pl": "bun compiler/compilePL.ts",
    "test": "bun test",
    "dev": "bun build.ts && bun --watch index.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "8.22.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^8.10.2",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^2.8.8"
  },
  "dependencies": {}
}
